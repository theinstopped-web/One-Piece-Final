local npcMap = {}
local function buildNPCList()
    npcMap = {}
    local names = {}
    for _, sub in ipairs({"Quest","DailyQuest","Shop"}) do
        local folder = getNPCFolder(sub)
        if folder then
            for _, npc in ipairs(folder:GetChildren()) do
                local label = ("[%s] %s"):format(sub, npc.Name)
                npcMap[label] = npc
                names[#names+1] = label
            end
        end
    end
    return names
end

