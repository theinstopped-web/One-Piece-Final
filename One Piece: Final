--==[ SAFE ATTACK (no mouse hijack) ]==----------------------------------------
-- The old SendMouseButtonEvent stole the real cursor. We instead fire the
-- click directly to the game with VirtualInputManager at the SCREEN CENTER
-- only when farming, and we throttle it so it never floods your input.
local _vim = game:GetService("VirtualInputManager")
local _lastClick = 0
local function attack()
    local now = os.clock()
    if now - _lastClick < 0.12 then return end   -- throttle = no mouse lock
    _lastClick = now
    pcall(function()
        _vim:SendMouseButtonEvent(0, 0, 0, true, game, 1)
        _vim:SendMouseButtonEvent(0, 0, 0, false, game, 1)
    end)
end

