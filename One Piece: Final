local function getAlive() return Workspace:FindFirstChild("Alive") end

-- parse "Lv12 Boar" -> 12
local function mobLevel(name)
    local n = tostring(name):match("Lv(%d+)")
    return n and tonumber(n) or 0
end

local function getMobs(maxDist, opts)
    opts = opts or {}
    local folder = getAlive(); if not folder then return {} end
    local hrp = getHRP(); if not hrp then return {} end
    local myPos = hrp.Position
    local out = {}
    for _, m in ipairs(folder:GetChildren()) do
        if m ~= getChar() then
            local h = m:FindFirstChildOfClass("Humanoid")
            local r = m:FindFirstChild("HumanoidRootPart")
            if h and r and h.Health > 0 then
                local isPlayer = Players:GetPlayerFromCharacter(m) ~= nil
                local pass = true
                if opts.mobsOnly and isPlayer then pass = false end
                if opts.bossOnly and not (m.Name:lower():find("boss") or mobLevel(m.Name) >= 150) then pass = false end
                if pass then
                    local d = (r.Position - myPos).Magnitude
                    if d <= maxDist then
                        out[#out+1] = {model=m, root=r, hum=h, dist=d, isPlayer=isPlayer, lvl=mobLevel(m.Name)}
                    end
                end
            end
        end
    end
    if opts.byLevel then
        table.sort(out, function(a,b) return a.lvl < b.lvl end)  -- weakest first
    else
        table.sort(out, function(a,b) return a.dist < b.dist end)
    end
    return out
end

local function tpToMob(t)
    local hrp = getHRP(); if not hrp then return end
    hrp.CFrame = CFrame.new(
        t.root.Position + Vector3.new(0, Flags.FarmHeight, 0) + t.root.CFrame.LookVector * -4,
        t.root.Position
    )
end

