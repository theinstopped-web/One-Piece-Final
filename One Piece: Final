local function equipWeapon(name)
    name = name or SelectedWeapon
    if not name then return end
    local hum = getHum()
    local char = getChar()
    if not hum or not char then return end
    -- already equipped?
    if char:FindFirstChild(name) then return end
    local bp = LocalPlayer:FindFirstChild("Backpack")
    local tool = bp and bp:FindFirstChild(name)
    if tool then pcall(function() hum:EquipTool(tool) end) end
end

--==[ CHEST COLLECT (forces pickup without manual move) ]==--------------------
-- Chests register via .Touched on the player's parts. TPing alone doesn't
-- fire Touched reliably, so we jitter the character to trigger the contact.
local function collectChest(chestPart)
    local hrp = getHRP()
    if not hrp or not chestPart then return end
    local target = (chestPart:IsA("BasePart") and chestPart) or chestPart:FindFirstChildWhichIsA("BasePart")
    if not target then return end
    -- TP onto the chest
    hrp.CFrame = target.CFrame + Vector3.new(0, 2, 0)
    -- Manually fire Touched both ways to guarantee pickup
    pcall(function()
        firetouchinterest(hrp, target, 0)
        firetouchinterest(hrp, target, 1)
    end)
    -- Small jitter as a fallback if firetouchinterest is unavailable
    task.wait(0.15)
    hrp.CFrame = target.CFrame + Vector3.new(0, 2, 1)
    task.wait(0.1)
    hrp.CFrame = target.CFrame + Vector3.new(0, 2, -1)
    task.wait(0.1)
end

--==[ AUTO RESPAWN (press Spawn button on death) ]==---------------------------
-- When farming and you die, the game shows a blue "Spawn" button.
-- This finds it in PlayerGui and clicks it so farming continues automatically.
local function pressSpawnButton()
    local pg = LocalPlayer:FindFirstChild("PlayerGui")
    if not pg then return false end
    for _, d in ipairs(pg:GetDescendants()) do
        if (d:IsA("TextButton") or d:IsA("ImageButton")) then
            local txt = (d:IsA("TextButton") and d.Text or "") or ""
            local nameMatch = d.Name:lower():find("spawn")
            if txt:lower():find("spawn") or nameMatch then
                -- fire all click signals to be safe
                pcall(function() firesignal(d.MouseButton1Click) end)
                pcall(function() firesignal(d.Activated) end)
                pcall(function() firesignal(d.MouseButton1Down) end)
                return true
            end
        end
    end
    return false
end

