local function getNPCFolder(sub)
    local ignore = Workspace:FindFirstChild("Ignore")
    local npcs = ignore and ignore:FindFirstChild("NPCs")
    return npcs and npcs:FindFirstChild(sub)
end
local function getChestsFolder() return Workspace:FindFirstChild("Chests") end
local function getMapFruits()
    local map = Workspace:FindFirstChild("MapFolder")
    return map and map:FindFirstChild("Fruits")
end
local function getIslands()
    local map = Workspace:FindFirstChild("MapFolder")
    if not map then return {} end
    local islands = {}
    for _, c in ipairs(map:GetChildren()) do
        if c.Name:match("^Island%d+") then
            islands[#islands+1] = c
        end
    end
    table.sort(islands, function(a,b)
        return (tonumber(a.Name:match("%d+")) or 0) < (tonumber(b.Name:match("%d+")) or 0)
    end)
    return islands
end

-- Get a usable pivot position from any model/part
local function getPivot(inst)
    if inst:IsA("BasePart") then return inst.CFrame end
    if inst:IsA("Model") then
        local ok, cf = pcall(function() return inst:GetPivot() end)
        if ok then return cf end
        local r = inst:FindFirstChild("HumanoidRootPart") or inst.PrimaryPart
        if r then return r.CFrame end
        local any = inst:FindFirstChildWhichIsA("BasePart")
        if any then return any.CFrame end
    end
    return nil
end

local function tpToCF(cf)
    local hrp = getHRP()
    if hrp and cf then hrp.CFrame = cf + Vector3.new(0, 4, 0) end
end

-- Teleport to the TOP of an island model so you never spawn in the ground.
-- Uses the model bounding box: top Y + a small clearance.
local function tpAboveModel(model, clearance)
    local hrp = getHRP()
    if not hrp or not model then return end
    clearance = clearance or 8
    local ok, cf, size = pcall(function() return model:GetBoundingBox() end)
    if ok and cf and size then
        local topY = cf.Position.Y + (size.Y / 2) + clearance
        hrp.CFrame = CFrame.new(cf.Position.X, topY, cf.Position.Z)
    else
        local piv = getPivot(model)
        if piv then hrp.CFrame = piv + Vector3.new(0, 20, 0) end
    end
end

--==[ PLAYER LEVEL (per-weapon, from _G.Data) ]==------------------------------
-- The game stores levels as _G.Data[UserId].Stats.<Class>.Level
-- We take the HIGHEST weapon level as your effective combat level.
local function getPlayerLevel()
    local best = 0
    pcall(function()
        local data = _G.Data and _G.Data[LocalPlayer.UserId]
        if data and data.Stats then
            for _, stat in pairs(data.Stats) do
                if type(stat) == "table" and type(stat.Level) == "number" then
                    if stat.Level > best then best = stat.Level end
                end
            end
        end
    end)
    return best
end

