local origBright, origClock, origFog = Lighting.Brightness, Lighting.ClockTime, Lighting.FogEnd
local function setFullbright(on)
    if on then Lighting.Brightness=2; Lighting.ClockTime=14; Lighting.GlobalShadows=false
    else Lighting.Brightness=origBright; Lighting.ClockTime=origClock; Lighting.GlobalShadows=true end
end
local function setNoFog(on)
    if on then Lighting.FogEnd=9e9
        for _,e in ipairs(Lighting:GetDescendants()) do if e:IsA("Atmosphere") then e.Density=0 end end
    else Lighting.FogEnd=origFog end
end

--==[ ESP ]==------------------------------------------------------------------
local espObjs = {}
local function makeESP(inst, color, text)
    if espObjs[inst] then return end
    local hl = Instance.new("Highlight")
    hl.FillColor=color; hl.FillTransparency=0.7; hl.OutlineColor=color
    hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop; hl.Parent=inst
    local bb = Instance.new("BillboardGui")
    bb.Size=UDim2.fromOffset(190,20); bb.StudsOffset=Vector3.new(0,3,0)
    bb.AlwaysOnTop=true; bb.Parent=inst
    local lbl = Instance.new("TextLabel")
    lbl.Size=UDim2.fromScale(1,1); lbl.BackgroundTransparency=1
    lbl.Font=Enum.Font.GothamMedium; lbl.Text=text; lbl.TextColor3=color
    lbl.TextSize=12; lbl.TextStrokeTransparency=0.4; lbl.Parent=bb
    espObjs[inst] = {hl=hl, bb=bb, lbl=lbl}
end
local function removeESP(inst)
    local e = espObjs[inst]
    if e then pcall(function() e.hl:Destroy(); e.bb:Destroy() end); espObjs[inst]=nil end
end
local function clearESP() for i in pairs(espObjs) do removeESP(i) end end

RunService.Heartbeat:Connect(function()
    local hrp = getHRP(); if not hrp then return end
    local anyOn = Flags.ESPMobs or Flags.ESPPlayers or Flags.ESPFruits or Flags.ESPChests
    if not anyOn then if next(espObjs) then clearESP() end return end
    local myPos = hrp.Position

    local folder = getAlive()
    if folder then
        for _, m in ipairs(folder:GetChildren()) do
            if m ~= getChar() then
                local r = m:FindFirstChild("HumanoidRootPart")
                local h = m:FindFirstChildOfClass("Humanoid")
                if r and h and h.Health > 0 then
                    local isPlayer = Players:GetPlayerFromCharacter(m) ~= nil
                    local d = (r.Position - myPos).Magnitude
                    local want = (isPlayer and Flags.ESPPlayers) or (not isPlayer and Flags.ESPMobs)
                    if want and d <= Flags.ESPMaxDist then
                        if not espObjs[m] then makeESP(m, isPlayer and Color3.fromRGB(232,110,110) or Color3.fromRGB(96,165,250), m.Name) end
                        if espObjs[m] then espObjs[m].lbl.Text = ("%s [%d]"):format(m.Name, math.floor(d)) end
                    elseif espObjs[m] then removeESP(m) end
                end
            end
        end
    end

    if Flags.ESPFruits then
        local fruits = getMapFruits()
        if fruits then
            for _, fr in ipairs(fruits:GetChildren()) do
                local part = fr:IsA("BasePart") and fr or fr:FindFirstChildWhichIsA("BasePart")
                if part and (part.Position-myPos).Magnitude <= Flags.ESPMaxDist and not espObjs[fr] then
                    makeESP(fr, Color3.fromRGB(126,211,145), "Fruit: "..fr.Name)
                end
            end
        end
    end

    if Flags.ESPChests then
        local chests = getChestsFolder()
        if chests then
            for _, ch in ipairs(chests:GetChildren()) do
                local part = ch:IsA("BasePart") and ch or ch:FindFirstChildWhichIsA("BasePart")
                if part and (part.Position-myPos).Magnitude <= Flags.ESPMaxDist and not espObjs[ch] then
                    makeESP(ch, Color3.fromRGB(255,200,80), "Chest: "..ch.Name)
                end
            end
        end
    end
end)


